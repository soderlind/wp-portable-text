{
	"name": "soderlind/wp-portable-text",
	"description": "Portable Text editor for WordPress — Composer dependencies",
	"type": "project",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=8.3"
	},
	"require-dev": {
		"phpunit/phpunit": "^12.0",
		"brain/monkey": "^2.6"
	},
	"autoload": {
		"classmap": [
			"includes/"
		]
	},
	"scripts": {
		"test": "phpunit"
	},
	"config": {
		"allow-plugins": {},
		"optimize-autoloader": true
	}
}